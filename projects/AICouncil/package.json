{
  "name": "aicouncil",
  "version": "0.1.0",
  "description": "Distributed epistemic consensus engine powered by Venice AI",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "workspaces": [
    "apps/web",
    "services/litellm",
    "services/council",
    "services/anything-llm",
    "services/flowise",
    "services/nft-minter",
    "middleware"
  ],
  "scripts": {
    "install:all": "npm install && npm run install:python",
    "install:python": "pip install -e . 2>/dev/null || true",
    "dev": "docker compose -f deploy/docker/docker-compose.dev.yml up",
    "prod": "docker compose -f deploy/docker/docker-compose.yml up -d",
    "down": "docker compose down",
    "clean": "npm run down && rm -rf node_modules build dist .next .pytest_cache && find . -type d -name __pycache__ -exec rm -rf {} + 2>/dev/null || true",
    "lint": "npm run lint:js && npm run lint:python",
    "lint:js": "eslint apps services middleware --max-warnings 0",
    "lint:python": "flake8 services middleware",
    "format": "npm run format:js && npm run format:python",
    "format:js": "prettier --write 'apps/**/*.{ts,tsx,js,jsx}' 'services/**/*.{ts,tsx,js,jsx}' 'middleware/**/*.{ts,tsx,js,jsx}'",
    "format:python": "black services middleware",
    "test": "npm run test:js && npm run test:python",
    "test:js": "jest apps services --coverage=true",
    "test:python": "pytest services middleware -v --cov",
    "test:integration": "docker compose -f deploy/docker/docker-compose.test.yml up --abort-on-container-exit",
    "build": "npm run build:apps && npm run build:services",
    "build:apps": "cd apps/web && npm run build",
    "build:services": "cd services && npm run build",
    "docker:build": "docker compose -f deploy/docker/docker-compose.yml build",
    "docker:push": "docker compose -f deploy/docker/docker-compose.yml push",
    "typecheck": "tsc --noEmit && mypy services middleware",
    "docs": "npm run docs:generate && npm run docs:serve",
    "docs:generate": "typedoc apps services --out docs/generated",
    "docs:serve": "http-server docs -c-1 -o -p 8888"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-prettier": "^5.0.1",
    "jest": "^29.7.0",
    "prettier": "^3.1.0",
    "typescript": "^5.2.2",
    "http-server": "^14.1.1",
    "typedoc": "^0.25.4"
  },
  "dependencies": {},
  "keywords": [
    "ai",
    "consensus",
    "council",
    "venice",
    "ollama",
    "litellm",
    "epistemic",
    "provenance",
    "blockchain",
    "sui",
    "arweave"
  ],
  "author": "AIcouncil Contributors",
  "license": "MIT"
}
